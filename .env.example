# Copy to .env and adjust values
# cp .env.example .env

# ZERION_WORKSPACE=
ZERION_OLLAMA_BASE_URL=http://localhost:11434

ZERION_EMBEDDING_MODEL=nomic-embed-text
ZERION_DEFAULT_MODEL=qwen2.5-coder:14b
ZERION_FAST_MODEL=qwen2.5-coder:7b
ZERION_HEAVY_MODEL=deepseek-coder-v2:16b
ZERION_VISION_MODEL=qwen2.5vl:7b
ZERION_CHAT_MODEL=llama3.1:8b

ZERION_CHROMA_PATH=.memory/chroma

ZERION_USE_NEO4J=false
ZERION_NEO4J_URI=bolt://localhost:7687
ZERION_NEO4J_USER=neo4j
ZERION_NEO4J_PASSWORD=change-me
